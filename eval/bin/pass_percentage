#!/bin/bash

# Script to print the pass percentage of an Inspect eval log and check against a threshold.

set -e

# Default threshold
THRESHOLD=0
LOG_FILE=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --threshold)
      THRESHOLD="$2"
      shift 2
      ;;
    *)
      if [ -z "$LOG_FILE" ]; then
        LOG_FILE="$1"
      else
        echo "Error: Unexpected argument: $1"
        echo "Usage: $0 [--threshold <value>] <log_file>"
        exit 1
      fi
      shift
      ;;
  esac
done

if [ -z "$LOG_FILE" ]; then
  echo "Usage: $0 [--threshold <value>] <log_file>"
  exit 1
fi

if [ ! -f "$LOG_FILE" ]; then
  echo "Error: File not found: $LOG_FILE"
  exit 1
fi

if ! command -v jq &> /dev/null; then
    echo "Error: jq is not installed. Please install it."
    exit 1
fi

# Get absolute path of the log file before we change directory
ABS_LOG_FILE=$(realpath "$LOG_FILE")

# Find project root (directory above bin)
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PROJECT_ROOT="$( dirname "$SCRIPT_DIR" )"

# Run command from project root to ensure `uv` finds the environment
cd "$PROJECT_ROOT"

# Extract accuracy and compute percentage using jq
PERCENTAGE=$(uv run inspect log dump --header-only "$ABS_LOG_FILE" | jq -r '.results.scores[0].metrics.accuracy.value * 100')

if [ "$PERCENTAGE" = "null" ] || [ -z "$PERCENTAGE" ]; then
  echo "Error: Could not find accuracy metric in log file."
  exit 1
fi

echo "${PERCENTAGE}%"

# Compare percentage with threshold using jq, because bash cannot handle
# floating point.
IS_GREATER_OR_EQUAL=$(jq -n "$PERCENTAGE >= $THRESHOLD")

if [ "$IS_GREATER_OR_EQUAL" = "false" ]; then
  echo "Error: Pass percentage ${PERCENTAGE}% is less than threshold ${THRESHOLD}%"
  exit 1
fi
