    <TextView
        android:id="@+id/tvSubStoryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="default"
        android:textSize="14sp"
        android:textColor="@color/text_secondary" />

</LinearLayout>