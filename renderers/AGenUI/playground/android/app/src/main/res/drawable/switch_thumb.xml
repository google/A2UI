<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#40000000" />
            <size
                android:width="28dp"
                android:height="28dp" />
        </shape>
    </item>
    
    <!-- White circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <size
                android:width="28dp"
                android:height="28dp" />
        </shape>
    </item>
</layer-list>