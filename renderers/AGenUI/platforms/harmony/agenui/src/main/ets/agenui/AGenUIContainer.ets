import { NodeContent } from '@ohos.arkui.node';
import { hilog } from '@kit.PerformanceAnalysisKit';
import internal_a2ui from 'liba2ui-capi.so';

/**
 * A2UI container component
 * Renders dynamic UI generated by AGenUI.
 *
 * Layout strategy:
 *   - Width: notify the native layer once on the first valid layout and ignore later width changes.
 *   - Height: leave unconstrained so content can expand naturally (WRAP_CONTENT).
 */
@Component
export struct AGenUIContainer {
  // Root content slot for dynamic UI rendering.
  private nodeContent: NodeContent = new NodeContent();
  // Width is sent to native only once; flag prevents redundant calls.
  private widthNotified: boolean = false;
  @Prop surfaceId: string = "";
  // engineId is resolved internally via native lookup; no longer required from callers.
  private resolvedEngineId: number = 0;

  /**
   * Called after the component is built
   * Initializes AGenUI and builds the node tree.
   */
  onDidBuild(): void {
    hilog.info(0x0000, 'agenui-ets', 'onDidBuild');
    AppStorage.setOrCreate<UIContext>("context", this.getUIContext());
    // Resolve engineId from surfaceId via native mapping (registered when surface was created).
    this.resolvedEngineId = internal_a2ui.findEngineIdBySurfaceId(this.surfaceId);
    // Pass nodeContent to C++ using the resolved engineId.
    const success: boolean = internal_a2ui.bindSurface(this.resolvedEngineId, this.surfaceId, this.nodeContent);
    if (success) {
      hilog.info(0x0000, 'agenui-ets', 'onDidBuild A2UI container bound to C++ successfully');
    } else {
      hilog.error(0x0000, 'agenui-ets', 'onDidBuild Failed to bind A2UI container to C++');
    }
  }

  /**
   * Called before the component is destroyed
   * Releases resources and tears down the node tree.
   */
  aboutToDisappear(): void {
    hilog.info(0x0000, 'agenui-ets', 'aboutToDisappear A2UI unbindSurface');
    internal_a2ui.unbindSurface(this.resolvedEngineId, this.surfaceId);
  }

  /**
   * Builds the UI
   */
  build() {
    // Leave height unconstrained so the Stack grows with its content.
    Stack() {
      ContentSlot(this.nodeContent)
    }
    .width('100%')
    .onSizeChange((oldValue: SizeOptions, newValue: SizeOptions) => {
      const newWidth = Math.round(newValue.width as number);

      // Notify the native layer only once after the first valid width is available.
      if (this.widthNotified || newWidth <= 0) {
        return;
      }

      this.widthNotified = true;
      // Pass height 0 so the native side can resolve it with wrap_content semantics.
      internal_a2ui.onSurfaceSizeChanged(this.surfaceId, newWidth, 0);
      hilog.info(0x0000, 'agenui-ets', 'onSizeChange notified native - width: %{public}d', newWidth);
    })
  }
}
