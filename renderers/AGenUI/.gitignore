# ============================================================================
# AGenUI monorepo - Root .gitignore
#
# Design principles:
#   - Root .gitignore only contains cross-platform general rules (OS, IDE, temp files, common artifacts)
#   - Platform-specific rules (Pods/, build/, oh_modules/, etc.) go into platforms/<plat>/.gitignore
#   - Do not override or duplicate rules already defined in sub .gitignore files
# ============================================================================

# ---------------------- OS Files ----------------------
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------- General IDE / Editors ----------------------
# JetBrains family (IntelliJ IDEA / Android Studio / DevEco Studio / CLion)
.idea/
*.iml
*.ipr
*.iws

# VS Code (to keep shared configs like .vscode/extensions.json, negate as needed)
.vscode/
*.code-workspace

# Vim / Emacs / Sublime
*.swp
*.swo
*~
.*.sw[a-p]
*.sublime-workspace
*.sublime-project

# Local cache for AI tools such as Cursor / Aone Copilot
.cursor/
.aone_copilot/

# ---------------------- General Build Artifacts ----------------------
# General build directories
build/
build-framework/
out/
dist/
target/

# Common CMake artifacts (may be generated under engine/, etc.)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!cmake/**/*.cmake
compile_commands.json
.cmake/

# General temporary files
*.tmp
*.temp
*.log
*.bak

# ---------------------- Node.js (may be used by scripting toolchain) ----------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# ---------------------- Python (may be generated by helper scripts) ----------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/

# ---------------------- Prebuilt Artifacts / Git LFS Placeholders ----------------------
# Actual artifacts under prebuilts/ will be tracked via LFS in the future; locally built copies are excluded from git
prebuilts/**/*.xcframework/
prebuilts/**/*.framework/
prebuilts/**/*.aar
prebuilts/**/*.har
prebuilts/**/*.so
prebuilts/**/*.a
prebuilts/**/*.dSYM/
prebuilts/**/*.zip

# ---------------------- Documentation Site Build Artifacts ----------------------
docs/.docusaurus/
docs/build/
docs/node_modules/
docs/_site/

# ---------------------- Other General Sensitive / Local Files ----------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ---------------------- Artifacts ----------------------
# Unified output directory for all three platforms (overwritten on each build; use git tag / CI artifact for persistence)
/dist/

# ---------------------- Playground local config ----------------------
playground/harmony/build-profile.json5
